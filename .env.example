# Create a WCA OAuth application at:
# https://www.worldcubeassociation.org/oauth/applications
#
# Set the redirect URI to: http://localhost:5173/auth/callback (for dev)
# or your deployed URL for production.

VITE_WCA_CLIENT_ID=your_client_id_here

# Client secret — no VITE_ prefix so it is NEVER exposed in the browser bundle.
# Only used by the Vite dev-server proxy to inject into the token exchange.
# Leave blank if your WCA OAuth app is non-confidential (public client).
WCA_CLIENT_SECRET=your_client_secret_here

# Optional: override the redirect URI (defaults to window.location.origin + /auth/callback)
# VITE_WCA_REDIRECT_URI=http://localhost:5173/auth/callback
